# IRON CUSTOMER REACH VMAX — environment example
# Copy to .env (frontend) and fill in real values.
# Worker secrets are set via `wrangler secret put` — see ENV_REFERENCE.md.

# ─── Frontend (Vite, prefixed VITE_) ────────────────────────────────────
VITE_API_BASE_URL=https://api.icrv.app
VITE_APP_NAME=ICRV
VITE_CF_ACCESS_TEAM=
VITE_CF_ACCESS_TEAM_DOMAIN=     # e.g. acme.cloudflareaccess.com (PR 6)
VITE_CF_ACCESS_AUD=             # Application AUD tag from Cloudflare Access (PR 6)

# Sentry — leave empty to disable Sentry entirely (PR 4)
VITE_SENTRY_DSN=
VITE_BUILD_SHA=                 # auto-injected by `npm run build` in PR 5

# ─── Workers — set via wrangler secret put <NAME> --name <worker> ──────
# SENTRY_DSN     — Sentry DSN for icrv-api / icrv-hooks / icrv-voice / icrv-agent
# ENVIRONMENT    — production | preview | dev
# (full reference in ENV_REFERENCE.md)
