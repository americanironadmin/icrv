{
  "name": "icrv-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && VITE_BUILD_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo dev) vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name icrv-dashboard"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "papaparse": "^5.4.1",
    "@sentry/react": "^8.40.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/papaparse": "^5.3.15",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^3.80.0"
  }
}
