{
  "name": "icrv-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "IRON CUSTOMER REACH VMAX — Cloudflare-only AI sales engagement platform",
  "workspaces": [
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "audit:a11y": "bash scripts/audit-a11y.sh",
    "audit:check": "bash scripts/audit-check.sh",
    "deploy:api": "npm run deploy --workspace=@icrv/api",
    "deploy:hooks": "npm run deploy --workspace=@icrv/hooks",
    "deploy:email": "npm run deploy --workspace=@icrv/email",
    "deploy:whatsapp": "npm run deploy --workspace=@icrv/whatsapp",
    "deploy:voice": "npm run deploy --workspace=@icrv/voice",
    "deploy:consumer": "npm run deploy --workspace=@icrv/consumer",
    "deploy:agent": "npm run deploy --workspace=@icrv/agent",
    "deploy:cron": "npm run deploy --workspace=@icrv/cron",
    "deploy:all": "bash scripts/deploy-all.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0",
    "@axe-core/cli": "^4.10.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
